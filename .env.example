# Copy this file to .env and fill in what you need.
# SentinelMCP runs entirely on free tiers — no paid API key required.

# --- Groq (recommended default — free tier, no credit card) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Ollama (fully local, zero rate limits, zero API key) ---
# Install from https://ollama.com, then: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# --- Per-agent provider routing ---
# Recommended free split: run Target locally on Ollama so you're not spending
# your Groq quota on both sides of the red-team exercise.
DEFAULT_PROVIDER=groq
ATTACKER_PROVIDER=groq
TARGET_PROVIDER=ollama
JUDGE_PROVIDER=groq
REPORTER_PROVIDER=groq

# --- Rate-limit pacing (tuned conservatively for Groq's free tier) ---
REQUEST_DELAY_SECONDS=2.5
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5

# --- Storage ---
SENTINEL_DB_PATH=sentinel.db
